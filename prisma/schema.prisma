// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PENDING_COD
  PENDING_ONLINE
  PENDING_TRANSFER
  PAID
  SHIPPED
  CANCELLED
}

enum DeliveryMethod {
  SHIPMENT
  PICKUP
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  COD
  PAY_ONLINE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  /** Optional link to Payload `store-customers` doc (Phase 3 bridge, not auth). */
  payloadCustomerId String? @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  addresses      UserAddress[]
  orders         Order[]
  reviews        Review[]
  wishlist       WishlistItem[]
  persistedCart  PersistedCart?
}

model PersistedCart {
  id        String   @id @default(cuid())
  userId    String   @unique
  /** JSON array: { productId, variantSku?, quantity } */
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailCampaign {
  id              String         @id @default(cuid())
  name            String
  subject         String
  body            String
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientCount  Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
}

model UserAddress {
  id          String   @id @default(cuid())
  userId      String
  title       String
  fullName    String
  phone       String
  addressLine String
  ward        String?
  district    String?
  city        String
  country     String   @default("Vietnam")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  discountType   CouponDiscountType
  /** Whole-number percent (1–100) or fixed VND off, depending on discountType. */
  discountValue  Int
  minOrderAmount Int                @default(0)
  maxUses        Int?
  usedCount      Int                @default(0)
  expiresAt      DateTime?
  enabled        Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Order {
  id              String          @id @default(cuid())
  orderCode       Int             @unique
  userId          String?
  /** Total charged (subtotal − discount + shipping), VND integer. */
  amount          Int
  /** Sum of line items before discount/shipping; null only on legacy rows. */
  subtotalAmount  Int?
  shippingAmount  Int             @default(0)
  discountAmount  Int             @default(0)
  couponCode      String?
  /** True after variant stock was decremented for this order. */
  inventoryAdjusted Boolean       @default(false)
  status          OrderStatus     @default(PENDING)
  buyerName       String?
  buyerEmail      String?
  buyerPhone      String?
  paymentUrl      String?
  paidAt          DateTime?
  deliveryMethod  DeliveryMethod?
  paymentMethod   PaymentMethod?
  paymentMethodKey String?
  paymentKind     String?
  customerName    String?
  phoneNumber     String?
  shippingAddress String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items OrderItem[]
  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderCode])
  @@index([status])
  @@index([userId])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  productId     String
  productTitle  String @default("")
  productHandle String @default("")
  variantSku    String?
  variantName   String?
  quantity      Int
  unitPrice     Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  productHandle String   @default("")
  rating        Int
  title         String?
  body          String
  approved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One review per user per product; updating re-submits for moderation.
  @@unique([userId, productId])
  @@index([productId])
  @@index([approved])
}

model WishlistItem {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  productHandle String   @default("")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  orderCode String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/** Digital gift cards — balance tracked in VND integers; redeemed at checkout. */
model GiftCard {
  id             String    @id @default(cuid())
  code           String    @unique
  /** Original issued value (VND). */
  initialBalance Int
  /** Remaining balance (VND). */
  balance        Int
  /** Total amount redeemed across orders (VND). */
  usedAmount     Int       @default(0)
  expiresAt      DateTime?
  enabled        Boolean   @default(true)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([enabled])
}
