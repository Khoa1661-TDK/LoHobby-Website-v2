    "payload:seed-products": "tsx scripts/seed-payload-products.ts",
    "payload:seed-catalog": "tsx scripts/seed-payload-categories.ts && tsx scripts/seed-payload-products.ts",
    "payload:cleanup-categories": "tsx scripts/cleanup-payload-categories.ts",
    "payload:backfill-images": "tsx scripts/backfill-product-images.ts",
