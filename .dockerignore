# Dependencies & build output (reinstalled/rebuilt inside the image)
node_modules
.next
generated
out
build

# Secrets — never copy real env into the image
.env
.env.*
!.env.example
# docker-compose.yml is gitignored and holds baked-in runtime secrets; it must
# never enter the build context. The example variant carries no secrets.
docker-compose.yml
!docker-compose.example.yml
# Dockerfile.private bakes live secrets; keep it out of the build context so
# `COPY . .` cannot copy the file into a layer (`-f Dockerfile.private` still
# works — the build file is read outside the context). Example variant is safe.
Dockerfile.private

# Local data that must not enter the image
public/media
*.sql
*.sql.gz
*.tgz

# VCS, docs, editor, CI noise
.git
.gitignore
docs
.claude
.superpowers
.vscode
.idea
*.log
coverage
.DS_Store
Thumbs.db
