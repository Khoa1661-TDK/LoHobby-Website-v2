# .env.example — copy to .env and fill values
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# payOS credentials (Sandbox or Production)
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# Storefront branding (used in <title> / <header> and Payload SEO generateTitle)
NEXT_PUBLIC_SITE_NAME="Lô Hobby"
# Canonical public origin for sitemap, Open Graph, and Payload SEO previews
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Comma-separated administrator emails. One login for storefront + admin (/admin).
# CMS accounts are auto-provisioned on first admin sign-in.
ADMIN_EMAILS="your-email@gmail.com"

# Payload CMS (v3) — used to sign the admin session cookie. Falls back to AUTH_SECRET if unset.
PAYLOAD_SECRET=""
# Set to true only when running `pnpm payload:db-push` after changing Payload collection fields.
# PAYLOAD_DB_PUSH="true"

# Auth.js (NextAuth v5)
AUTH_SECRET=""
# Local dev: must match the URL in your browser (fixes Google OAuth / session cookies)
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
