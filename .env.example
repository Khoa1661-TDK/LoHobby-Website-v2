# Copy to .env — DATABASE_URL is written automatically by:
#   npx prisma postgres link --database "<your-db-id>"
# Never commit .env (see .gitignore).

DATABASE_URL=""
# Optional override for Prisma Studio only (defaults to DATABASE_URL)
STUDIO_DATABASE_URL=""
# Direct connection for Prisma Migrate (pooled URL above is fine for the app runtime)
DIRECT_URL=""

# Prisma Studio tips:
# - Use a plain postgres:// or postgresql:// URL (not prisma:// or prisma+postgres://)
# - Remove ?schema=public from the URL (invalid for postgres.js introspection)
# - Run: npm run prisma:studio  (loads .env and strips bad query params)

# payOS credentials (Sandbox or Production)
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# Storefront branding
NEXT_PUBLIC_SITE_NAME="PolyToys"
# Canonical production URL (no trailing slash) — used for OG, sitemap, robots, canonical tags
NEXT_PUBLIC_SITE_URL="https://example.com"
# Optional: Verification tokens for Search Console / Yandex / Bing
GOOGLE_SITE_VERIFICATION=""
# Optional: Twitter @handle (without the @) for Twitter Card metadata
NEXT_PUBLIC_TWITTER_HANDLE=""
