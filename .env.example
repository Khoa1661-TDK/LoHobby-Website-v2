# =============================================================================
# RUNTIME / DEPLOY secret file — NOT a build requirement.
#
# This file is consumed at `docker run` time (via `env_file: .env` in
# docker-compose.yml) to inject secrets into the running container. It never
# enters the Docker image: the Dockerfile bakes in only generic NEXT_PUBLIC_*
# defaults + fake build-only placeholders for DATABASE_URL/PAYLOAD_SECRET.
#
# NEXT_PUBLIC_* values below are read by `docker compose build` to override the
# image's generic build-arg defaults (site name, domain, contact info) — set
# them here so your rebuild reflects your branding. Because Next.js inlines
# NEXT_PUBLIC_* at build time, changing them requires a rebuild.
#
# Copy to `.env` on your deploy server and fill in the real secret values.
# `.env` is gitignored — never commit it. If it is ever committed or baked into
# an image, rotate EVERY secret in it (DB token, Google OAuth, PayOS, etc.).
# =============================================================================
# Database — PostgreSQL connection string (Prisma + Payload share one DB).
# Points at the bundled `db` Postgres service in docker-compose.yml. Migrations
# run against this local DB on container start. For host-based dev (`pnpm dev`)
# use localhost:5432 instead — the same DB is published there.
#   In Docker:  postgres://shopnex:shopnex@db:5432/shopnex
#   Host dev:   postgresql://shopnex:shopnex@localhost:5432/shopnex
# =============================================================================
DATABASE_URL=postgres://shopnex:shopnex@db:5432/shopnex

# =============================================================================
# Payload CMS — admin session encryption secret. Generate: openssl rand -base64 32
# =============================================================================
PAYLOAD_SECRET=CHANGE_ME

# =============================================================================
# NextAuth (Auth.js v5)
# =============================================================================
# JWT secret (falls back to PAYLOAD_SECRET if unset). Generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME
# Canonical public base URL — your real domain, https.
AUTH_URL=https://your-domain.example
# Google OAuth (optional). Redirect URI to authorize in Google console:
#   https://your-domain.example/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# =============================================================================
# Public URLs — SEO, redirects, absolute URLs. Use your real domain.
# =============================================================================
# Canonical base URL, read at RUNTIME (not inlined like NEXT_PUBLIC_*). Set this
# to re-point the admin panel, SEO/canonical URLs, admin session cookies, and
# payment return/cancel URLs on a prebuilt image (e.g. Portainer on another
# host) with NO rebuild. Takes
# precedence over the NEXT_PUBLIC_* vars below; leave unset for Vercel/local.
APP_URL=https://your-domain.example
# Inlined into the client bundle at BUILD time — changing these needs a rebuild.
# Optional: omit for Docker builds to avoid baking a domain (runtime APP_URL
# above will be used instead). Set for Vercel / local dev.
NEXT_PUBLIC_APP_URL=https://your-domain.example
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# =============================================================================
# Branding (can be overridden via Payload CMS)
# =============================================================================
NEXT_PUBLIC_SITE_NAME=Your Store
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_ADDRESS=

# =============================================================================
# Payments & secrets
# =============================================================================
# Encryption key for stored payment credentials (falls back to AUTH_SECRET).
# Generate: openssl rand -base64 32
PAYMENT_SECRETS_KEY=CHANGE_ME
# PayOS (Vietnamese gateway). Encrypted credentials live on the CMS payment method.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# =============================================================================
# Admin allowlist — comma-separated emails allowed into Payload admin.
# =============================================================================
ADMIN_EMAILS=you@example.com

# =============================================================================
# Page-builder live preview / draft mode (admin-only token).
# Generate: openssl rand -base64 32
# =============================================================================
PREVIEW_SECRET=CHANGE_ME

# =============================================================================
# Page-builder AI assistant — OpenAI-compatible LLM (server-only)
# Defaults to Google Gemini Flash (free AI Studio key: https://aistudio.google.com/apikey).
# To use DeepSeek / OpenRouter instead, set BASE_URL + MODEL — no code change:
#   DeepSeek:   BASE_URL=https://api.deepseek.com         MODEL=deepseek-chat
#   OpenRouter: BASE_URL=https://openrouter.ai/api/v1     MODEL=google/gemini-2.0-flash-exp:free
# =============================================================================
ASSISTANT_LLM_API_KEY=
# Optional overrides (defaults shown):
# ASSISTANT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# ASSISTANT_LLM_MODEL=gemini-2.5-flash

# Public domain used by Caddy for TLS (read by docker-compose / Caddyfile).
DOMAIN=your-domain.example

# =============================================================================
# Mirror-on-create auto-translation (page builder). Optional: if unset, newly-added blocks
# are still mirrored across locales but their text is copied untranslated (with a warning).
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
